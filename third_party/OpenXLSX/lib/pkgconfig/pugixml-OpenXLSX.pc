# Patched by OpenXLSX installer: prepended -L${exec_prefix}/lib/OpenXLSX to Libs to accommodate custom library location
prefix=D:/CODE/CPP_Lib/OpenXLSX/build/install
exec_prefix=${prefix}
includedir=${prefix}/include
libdir=${exec_prefix}/lib

Name: pugixml
Description: Light-weight, simple and fast XML parser for C++ with XPath support.
URL: https://pugixml.org/
Version: 1.15
Cflags: -I${includedir}
Libs: -L${exec_prefix}/lib/OpenXLSX -L${libdir} -lpugixml
